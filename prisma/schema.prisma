generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  relationMode      = "prisma"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  name          String?
  producer_name String?   @unique
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  ideas         Idea[]    @relation("userIdeas")
  liked_ideas   Idea[]    @relation("IdeaUserLikes")
  contributions Contribution[] @relation("UserContributions")
}

model Idea {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  tag_one     String
  tag_two     String
  file        String   @unique
  createdAt   DateTime @default(now())
  slug        String?  @unique
  contributions Contribution[] @relation("IdeaContributions")
  likes       User[]   @relation("IdeaUserLikes")
  user        User     @relation("userIdeas", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@fulltext([tag_one, tag_two])
  @@fulltext([title, description])
  @@fulltext([title, description, tag_one, tag_two])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model IdeaUserLikes {
  A String
  B String

  @@unique([A, B], map: "_IdeaUserLikes_AB_unique")
  @@index([B], map: "_IdeaUserLikes_B_index")
  @@map("_IdeaUserLikes")
}

model Contribution {
  id          String @id @default(cuid())
  userId      String
  ideaId      String
  user        User   @relation("UserContributions", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  idea        Idea   @relation("IdeaContributions", fields: [ideaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  description String
  file        String
  status      status

  @@unique([userId, ideaId])
  @@index([userId])
  @@index([ideaId])
}


enum status {
  PENDING
  APPROVED
  REJECTED
}


enum Role {
  USER
  ADMIN
}
